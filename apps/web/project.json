{
  "name": "web",
  "sourceRoot": "apps/web/src",
  "projectType": "application",
  "tags": ["type:app", "scope:web"],
  "targets": {
    "serve": { "command": "vite --config apps/web/vite.config.ts" },
    "build": { "command": "vite build --config apps/web/vite.config.ts" },
    "typecheck": { "command": "tsc -p apps/web/tsconfig.json --noEmit" },
    "test": { "command": "vitest run --passWithNoTests apps/web" }
  }
}
