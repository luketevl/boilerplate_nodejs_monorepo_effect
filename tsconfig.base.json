{
  "compilerOptions": {
    "target": "ES2024",
    "jsx": "react-jsx",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@auto-freela/core": ["./packages/core/src/index.ts"],
      "@auto-freela/effect": ["./packages/effect/src/index.ts"],
      "@auto-freela/domain": ["./packages/domain/src/index.ts"],
      "@auto-freela/ports": ["./packages/ports/src/index.ts"],
      "@auto-freela/application": ["./packages/application/src/index.ts"],
      "@auto-freela/adapters": ["./packages/adapters/src/index.ts"],
      "@auto-freela/testing": ["./packages/testing/src/index.ts"],
      "@auto-freela/config": ["./packages/config/src/index.ts"]
    },
    "resolveJsonModule": true,
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  }
}
