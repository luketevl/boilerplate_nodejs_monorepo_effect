{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "apps/*/src/main.{ts,tsx}",
    "packages/*/src/index.ts"
  ],
  "ignoreDependencies": [
    "@nx/js",
    "@nx/react",
    "@testing-library/jest-dom",
    "@testing-library/react"
  ],
  "project": [
    "apps/**/*.{ts,tsx}",
    "packages/**/*.ts",
    "*.js"
  ]
}
